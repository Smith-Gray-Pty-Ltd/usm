{
  "$schema": "https://usm.dev/schema/usmconfig-v1.json",
  "version": "1",
  "name": "@smithgray/usm",
  "sources": {
    "root": ".",
    "include": ["src/**/*"],
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.next/**",
      "**/build/**",
      "**/.usm/**",
      "**/tests/**"
    ],
    "package_manifests": ["**/package.json"],
    "code_globs": ["**/*.ts"]
  },
  "shared": [],
  "services": [
    {
      "id": "cli",
      "match": "src/cli",
      "kind": "service",
      "summary": "usm CLI — init, scan, validate, generate, enrich commands"
    },
    {
      "id": "mcp",
      "match": "src/mcp",
      "kind": "service",
      "summary": "usm MCP server — 12 tools for AI agents (8 read + 4 write)"
    }
  ],
  "data": [],
  "outputs": {
    "workspace": ".usm-workspace",
    "docs": ".usm-workspace/docs",
    "help_docs": ".usm-workspace/help-docs",
    "archimate": ".usm-workspace/archimate",
    "togaf": ".usm-workspace/togaf",
    "openapi": ".usm-workspace/openapi",
    "tests": ".usm-workspace/tests",
    "usm_source": ".usm",
    "agents_md": "AGENTS.md"
  },
  "generation": {
    "merge_with_existing": "smart",
    "preserve_comments": true,
    "format": "github-flavored-markdown"
  },
  "enrichment": {
    "enabled": false
  }
}
