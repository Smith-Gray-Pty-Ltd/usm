$schema: https://usm.dev/schema/v1.json
$id: usm/mkt-language-tabs
$type: feature
$version: 1
$last_updated: "2026-06-30"
status: planned
summary: |
  Marketing site language support section — tabbed UI showing all 12 supported languages with their frameworks, monochrome logos, and route detection examples. Demonstrates USM's language-agnostic scanner.

$system: usm/system
$service: usm/cli
intent: |
  The marketing site currently says "Works with Cursor, Claude Code" but doesn't
  show that USM scans 12 languages and 30+ frameworks. A tabbed section with
  per-language framework lists, monochrome logos, and a route detection example
  per language would communicate the breadth of support visually.

decisions:
  - id: tabbed-interface
    decision: Use a tabbed interface with one tab per language
    rationale: |
      12 languages in a flat list is overwhelming. Tabs let visitors jump to
      their language and see supported frameworks + route detection example
      without scrolling through everything.
    consequences: "Need a Tabs component from shadcn (already available)"
    status: accepted
  - id: monochrome-logos
    decision: Use monochrome (white/grayscale) logos for frameworks
    rationale: |
      The site is dark monochrome theme. Colored logos would clash. Monochrome
      logos (opacity-based, hover to full opacity) match the premium aesthetic.
    consequences: "Need SVG logos for each framework — can use simple-icons or custom SVGs"
    status: accepted
  - id: route-example-per-language
    decision: Show a code snippet of route detection per language
    rationale: |
      Seeing the actual syntax (e.g. @app.get vs @GetMapping vs [HttpGet])
      helps developers understand what the scanner detects. It's concrete
      and instantly recognisable.
    consequences: "Each tab needs a short code example showing route syntax"
    status: accepted

flows:
  - id: render-language-tabs
    name: Render tabbed language support section
    description: |
      A new section on the marketing site between "Token Comparison" and
      "Tool Logos". Tabs for each language, showing frameworks as logo
      chips and a route detection code example.
    steps:
      - id: s1
        action: render
        target: "section heading 'Scans 12 languages, 30+ frameworks'"
      - id: s2
        action: render
        target: "tab bar with 12 language tabs (TS, Python, Go, Rust, Java, C#, Ruby, PHP, Elixir, Swift, Scala, C++)"
      - id: s3
        action: render
        target: "active tab content: framework logo chips + route detection code example"
      - id: s4
        action: observe
        target: "user clicks tab to switch language"

contracts:
  - id: all-languages-tabbed
    description: All 12 languages have a tab with frameworks and code example
    must_have:
      - "TypeScript tab: Next.js, Express, Hono logos + app.get example"
      - "Python tab: FastAPI, Flask, Django logos + @app.get example"
      - "Go tab: chi, gin, echo, net/http logos + r.GET example"
      - "Rust tab: Axum, Actix, Rocket logos + .route() example"
      - "Java tab: Spring Boot, Javalin, Quarkus logos + @GetMapping example"
      - "C# tab: ASP.NET Core logos + [HttpGet] example"
      - "Ruby tab: Rails, Sinatra logos + get '/path' example"
      - "PHP tab: Laravel, Symfony, Slim logos + Route::get example"
      - "Elixir tab: Phoenix logo + get '/path' example"
      - "Swift tab: Vapor logo + routes.get example"
      - "Scala tab: Akka HTTP, Play, Tapir logos + path example"
      - "C++ tab: Crow, Drogon, Pistache logos + CROW_ROUTE example"
  - id: monochrome-logos
    description: Framework logos are monochrome, hover to full opacity
    must_have:
      - "All logos rendered in white/grayscale at 50% opacity"
      - "Hover increases to 100% opacity"
      - "Logos are SVG (crisp at all sizes)"
  - id: responsive-tabs
    description: Tabs work on mobile
    must_have:
      - "Tab bar scrolls horizontally on mobile"
      - "Active tab is clearly highlighted"
      - "Code examples wrap on small screens"

tests:
  - id: all-tabs-present
    setup:
      page_loaded: true
    expect:
      - assertion: "12 language tabs visible"
      - assertion: "clicking each tab shows frameworks + code example"
  - id: default-tab
    setup:
      page_loaded: true
    expect:
      - assertion: "TypeScript tab is active by default"
  - id: mobile-scroll
    setup:
      mobile_viewport: true
    expect:
      - assertion: "tab bar scrolls horizontally"
      - assertion: "active tab visible without horizontal scroll"

implementation:
  primary: web/src/app/page.tsx
  test_code: ""
  test_code_status: none

see_also:
  - "usm/cli-multi-lang-scan"
