$schema: https://usm.dev/schema/v1.json
$id: usm/cli-enrich
$type: feature
$version: 1
$last_updated: "2026-06-19"
summary: "The usm enrich command fills in TODO: describe placeholders in .usm files using an LLM (LiteLLM, OpenAI, Anthropic, or Ollama)."

$system: usm/system
$service: usm/cli
command: enrich
intent: |
  Scanned .usm files contain TODO placeholders for summary, intent, decisions, flows, contracts, and tests. Enrich calls an LLM with source code context to fill these in, preserving existing human-written content.

flows:
  - id: enrich-single-file
    name: Enrich a single .usm file
    description: User enriches one file with LLM-generated content
    steps:
      - id: s1
        action: parse
        target: .usm file with TODO placeholders
      - id: s2
        action: setup
        target: source code context from referenced file paths
      - id: s3
        action: post
        target: LLM API with system prompt + user prompt
      - id: s4
        action: parse
        target: LLM response YAML
      - id: s5
        action: merge
        target: filled fields into original .usm, preserving human edits

contracts:
  - id: enrich-preserves-human-edits
    description: Enrich must never overwrite fields that already have non-TODO content
    must_have:
      - "Fields with TODO: describe are filled"
      - "Fields with existing content are preserved"
      - "preserve_human_edits defaults to true"

tests:
  - id: enrich-fills-todos
    setup:
      usm_with_todo_fields: true
    expect:
      - assertion: TODO fields replaced with LLM content
      - assertion: non-TODO fields unchanged
  - id: enrich-dry-run
    setup:
      dry_run: true
    expect:
      - assertion: no files written
      - assertion: planned changes reported

usage:
  - command: "usm enrich"
    description: "Enrich all .usm files with TODO placeholders"
  - command: "usm enrich --file .usm/features/auth/login.usm"
    description: "Enrich a single file"
  - command: "usm enrich --dry-run"
    description: "Show what would change without calling LLM or writing"
  - command: "usm enrich --model anthropic/claude-sonnet-4-5"
    description: "Override the LLM model"

options:
  - flag: "--root <root>"
    description: "Monorepo root directory"
    default: "current directory"
  - flag: "--file <file>"
    description: "Single .usm file to enrich"
    default: "all files with TODOs"
  - flag: "--dry-run"
    description: "Show changes without writing or calling LLM"
    default: "false"
  - flag: "--fields <fields>"
    description: "Comma-separated fields to enrich"
    default: "summary,intent,decisions,flows,contracts,tests,status"
  - flag: "--model <model>"
    description: "Override LLM model"
    default: "from usmconfig.json"
  - flag: "--provider <provider>"
    description: "Override provider (litellm|openai|anthropic|ollama)"
    default: "from usmconfig.json"
  - flag: "--url <url>"
    description: "Override LLM API URL"
    default: "from usmconfig.json"

prerequisites:
  - ".usm files with TODO: describe placeholders"
  - "LLM provider configured in usmconfig.json or via flags"

implementation:
  primary: src/enrich/index.ts
  test_code: ""
  test_code_status: none

see_also:
  - "usm/cli-scan"
