    ref: .usm/services/mcp.usm

apis: []
data:
  - id: usm-config
    name: USM Config
    ref: .usm/data/usm-config.usm

infrastructure:
  cloud: cloudflare
  region: global
  dns: usm.dev
  ssl: cloudflare-managed

deployment:
  environments:
    - name: dev
      url: "http://localhost:5173"
      type: local
      notes: "usm docs serve — VitePress dev server"
    - name: production
      url: "https://usm.dev"
      type: cloudflare-pages
      build_command: "pnpm install --frozen-lockfile && pnpm add -D vitepress && pnpm run build && node dist/cli/index.js generate && node dist/cli/index.js docs build"
      output_directory: ".usm-workspace/docs/.vitepress/dist"
      project_name: usm-dev
      secrets:
        - CLOUDFLARE_API_TOKEN
        - CLOUDFLARE_ACCOUNT_ID
      notes: |
        Deployed via GitHub Actions on push to main (.github/workflows/docs.yml).
        Cloudflare Pages — free tier (unlimited static sites, requests, bandwidth).

operations:
  deployment_setup: |
    One-time Cloudflare Pages setup:
    1. Create Cloudflare API token (Pages:Edit, Account:Read scopes)
    2. Add GitHub secrets: CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
    3. Create Pages project 'usm-dev' connected to GitHub repo
    4. Set build output directory: .usm-workspace/docs/.vitepress/dist
    5. Add custom domain usm.dev (CNAME auto-added by Cloudflare)
  monitoring: "Cloudflare Pages dashboard — build status and deploy logs"
  alerts: "GitHub Actions workflow failure notifications"

roadmap:
  - id: vitepress-docs
    title: VitePress docs integration
    description: "usm docs serve and usm docs build with auto-generated sidebar, angle bracket escaping, and index page"
    status: shipped
    target_date: "2026-06-22"
    feature: usm/cli-docs
    shipped_in: "1.1.0"
  - id: review-quality-markdown
    title: Review-quality feature markdown
    description: "Flows as numbered steps, contracts as checklists, tests as Given/When/Then, decisions with alternatives"
    status: shipped
    target_date: "2026-06-22"
    feature: usm/gen-feature-review
    shipped_in: "1.1.0"
  - id: empty-section-suppression
    title: Suppress empty sections in generated docs
    description: "No more empty App Services, No UI pages documented, or No risks defined pages"
    status: shipped
    target_date: "2026-06-22"
    shipped_in: "1.1.0"
  - id: roles-schema
    title: Roles field in system schema
    description: "Any project can describe who uses their system and what they need"
    status: shipped
    target_date: "2026-06-22"
    shipped_in: "1.1.0"
  - id: adr-schema-enrichment
    title: ADR schema enrichment
    description: "Alternatives and consequences fields on decisions for proper ADR-style recording"
    status: shipped
    target_date: "2026-06-22"
    shipped_in: "1.1.0"
  - id: roadmap-improvements
    title: Roadmap with feature links and delivery tracking
    description: "Roadmap items link to feature specs, show shipped_in version, sidebar dead links fixed, mermaid rendering"
    status: in-progress
    feature: usm/gen-roadmap
  - id: agent-authoring-tools
    title: MCP write tools
    description: "draft_feature, update_feature_status — close the spec-first loop so agents can author .usm files"
    status: shipped
    feature: usm/mcp-write
    shipped_in: "1.1.0"
  - id: rules-file-generation
    title: Tool-specific rules files
    description: "Generate .cursor/rules, CLAUDE.md, copilot-instructions.md with spec-first workflow instructions"
    status: shipped
    feature: usm/gen-rules-files
    shipped_in: "1.1.0"
  - id: marketing-site
    title: Marketing site
    description: "Next.js + shadcn landing page at usm.dev with spec-first workflow story"
    status: planned

principles:
  - key: structured-source-of-truth
    name: Structured Source of Truth
    statement: Every system artifact is captured in YAML validated by a JSON Schema — no scattered, stale docs.
    rationale: Agents and humans need a single, machine-checkable source. Free-form docs drift; schema-validated YAML stays consistent.
    implications:
      - All system descriptions must live in .usm/ YAML files
      - The v1 JSON Schema is the contract — no undocumented fields
  - key: agent-first
    name: Agent First
    statement: USM files are designed for AI agent consumption via MCP tools before human readability.
    rationale: The MCP server exposes 12 tools (8 read + 4 write) that let agents navigate, search, reference, and author USM data without reading raw YAML.
    implications:
      - Every .usm field must be parseable and queryable by agents
      - The MCP server must stay in sync with the schema
  - key: idempotent-generation
    name: Idempotent Generation
    statement: Scan and generate are safe to run repeatedly; smart-merge preserves human edits.
    rationale: Re-running usm scan or usm generate should never destroy hand-written content. The smart-merge strategy preserves human-edited fields and updates mechanical ones.
    implications:
      - Smart-merge distinguishes human-edited from scan-derived fields
      - --force bypasses merge for intentional overwrite
  - key: one-source-many-outputs
    name: One Source, Many Outputs
    statement: A single .usm/ directory generates markdown, Mermaid, OpenAPI, ArchiMate, TOGAF, AGENTS.md, and Vitest specs.
    rationale: Maintaining 6+ doc formats independently is unsustainable. Derive all from one source so they stay in sync.
    implications:
      - Generators must read .usm files — never write docs from other docs
      - Each generator is independent and composable

roles:
  - name: Human Developer
    description: |
      Reviews feature specs before approving implementation. Discusses features
      with an AI agent, reviews the generated markdown, and approves or requests
      changes before the agent builds.
    needs:
      - "Readable feature specs with clear intent, flows, and contracts"
      - "Checklist-format acceptance criteria for quick review"
      - "Given/When/Then test format to verify coverage"
  - name: AI Agent
    description: |
      Reads .usm files via MCP tools to understand system context before
      implementing features. Drafts feature specs from human discussion.
    needs:
      - "MCP tools to query system structure without reading raw YAML"
      - "Write tools to draft and update feature specs"
      - "Rules files that teach the spec-first workflow"
  - name: New Visitor
    description: |
      Finds USM on GitHub or npm and visits usm.dev to evaluate whether to use
      it in their project.
    needs:
      - "Clear value proposition and workflow description"
      - "Quick start guide"
      - "Example feature specs"
  - name: Team Member
    description: |
      Joins a project that uses USM and needs to understand the system
      architecture, services, and feature inventory.
    needs:
      - "System overview with architecture diagram"
      - "Service descriptions with links to features"
      - "Local development setup guide"
  - name: Technical Lead
    description: |
      Reviews system design, tracks risks and roadmap, ensures architectural
      consistency across features.
    needs:
      - "Cross-cutting views — decisions, risks, roadmap"
      - "Architecture diagrams"
      - "Feature status overview (planned vs built)"
