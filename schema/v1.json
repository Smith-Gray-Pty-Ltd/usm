{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://usm.dev/schema/v1.json",
  "title": "Universal System Map v1",
  "description": "Schema for .usm files \u2014 the structured source of truth for agentic systems",
  "oneOf": [
    {
      "$ref": "#/$defs/systemFile"
    },
    {
      "$ref": "#/$defs/serviceFile"
    },
    {
      "$ref": "#/$defs/featureFile"
    }
  ],
  "$defs": {
    "commonFields": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "const": "https://usm.dev/schema/v1.json",
          "description": "Schema reference URI"
        },
        "$id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*$",
          "description": "Unique identifier: system/name (e.g. smith-gray/system)"
        },
        "$type": {
          "type": "string",
          "enum": [
            "system",
            "service",
            "feature",
            "api",
            "data",
            "policy",
            "operations"
          ],
          "description": "File type discriminator"
        },
        "$version": {
          "type": "integer",
          "minimum": 1,
          "description": "Schema version (starts at 1)"
        },
        "$last_updated": {
          "type": "string",
          "format": "date",
          "description": "Last update date (ISO 8601 date)"
        },
        "summary": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "1-3 sentence summary for quick agent scan"
        }
      },
      "required": [
        "$schema",
        "$id",
        "$type",
        "$version",
        "summary"
      ]
    },
    "systemFile": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "const": "https://usm.dev/schema/v1.json"
        },
        "$id": {
          "type": "string"
        },
        "$type": {
          "type": "string",
          "const": "system"
        },
        "$version": {
          "type": "integer"
        },
        "$last_updated": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "built", "deprecated"],
          "default": "built",
          "description": "Implementation status: planned (no code yet), in-progress (partial code), built (code exists), deprecated (replaced by something else)"
        },
        "identity": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "domain": {
              "type": "string"
            },
            "contact": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "domain"
          ],
          "additionalProperties": false
        },
        "index": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "planned",
                  "deprecated",
                  "experimental"
                ]
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "name",
              "ref"
            ],
            "additionalProperties": false
          }
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "depends_on": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "name",
              "ref"
            ],
            "additionalProperties": false
          }
        },
        "apis": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "ref"
            ],
            "additionalProperties": false
          }
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "ref"
            ],
            "additionalProperties": false
          }
        },
        "infrastructure": {
          "type": "object",
          "properties": {
            "cloud": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "terraform_ref": {
              "type": "string"
            },
            "dns": {
              "type": "string"
            },
            "ssl": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "deployment": {
          "type": "object",
          "properties": {
            "environments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "notes": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ],
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "operations": {
          "type": "object",
          "properties": {
            "monitoring": {
              "type": "string"
            },
            "alerts": {
              "type": "string"
            },
            "on_call": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "policies": {
          "type": "object",
          "properties": {
            "refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
              "status": { "type": "string", "enum": ["identified", "mitigated", "accepted", "materialized"] },
              "mitigation": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "roadmap": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "status": { "type": "string", "enum": ["planned", "in-progress", "shipped", "cancelled"] },
              "target_date": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "agent_context": {
          "type": "string",
          "description": "Markdown content for AI agent context — critical distinctions, usage modes, etc."
        },
        "conventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Platform-wide conventions that all agents must follow"
        },
        "mandatory_reading": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["path"],
            "additionalProperties": false
          },
          "description": "Documents that must be read before any work"
        },
        "nextjs_breaking_changes": {
          "type": "string",
          "description": "Markdown content describing Next.js 16 breaking changes (middleware→proxy, Turbopack, etc.)"
        },
        "principles": {
          "type": "array",
          "description": "TOGAF Architecture Principles — the rules and values that govern all architecture decisions.",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string", "description": "kebab-case identifier" },
              "name": { "type": "string", "description": "Short human-readable name" },
              "statement": { "type": "string", "description": "The principle itself" },
              "rationale": { "type": "string", "description": "Why this principle matters" },
              "implications": { "type": "array", "items": { "type": "string" }, "description": "What following this principle means in practice" }
            },
            "required": ["key", "name", "statement", "rationale"]
          }
        },
        "roles": {
          "type": "array",
          "description": "User roles — who uses this system and what they need from the docs and tools.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Role name (e.g. Human Developer, AI Agent, New Team Member)" },
              "description": { "type": "string", "description": "Who this role is and when they interact with the system" },
              "needs": { "type": "array", "items": { "type": "string" }, "description": "What this role needs from the docs/tools (e.g. 'Readable feature specs for review')" }
            },
            "required": ["name", "description"],
            "additionalProperties": false
          }
        },
        "local_development": {
          "type": "object",
          "description": "Local development workflow — commands, quirks, log locations, and external services required to run the platform on a developer's machine.",
          "properties": {
            "monorepo": {
              "type": "object",
              "properties": {
                "package_manager": { "type": "string" },
                "package_manager_version": { "type": "string" },
                "node_version": { "type": "string" },
                "install_command": { "type": "string" },
                "workspace_pattern": { "type": "string" }
              }
            },
            "apps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "port": { "type": "integer" },
                  "dev_command": { "type": "string" },
                  "url_local": { "type": "string" },
                  "requires_db": { "type": "boolean" }
                }
              }
            },
            "external_services": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "port": { "type": "integer" },
                  "purpose": { "type": "string" },
                  "managed_by": { "type": "string" }
                }
              }
            },
            "environment": {
              "type": "object",
              "properties": {
                "root_env": { "type": "string", "description": "Path to root .env file" },
                "per_app_env": { "type": "array", "items": { "type": "string" } },
                "required_vars": { "type": "array", "items": { "type": "string" } }
              }
            },
            "log_locations": {
              "type": "object",
              "properties": {
                "dev_server": { "type": "string" },
                "build_output": { "type": "string" },
                "test_output": { "type": "string" }
              }
            },
            "known_quirks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "workaround": { "type": "string" },
                  "affected_command": { "type": "string" },
                  "fixed_in": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "required": [
        "$schema",
        "$id",
        "$type",
        "$version",
        "summary",
        "identity"
      ],
      "additionalProperties": false
    },
    "serviceFile": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "const": "https://usm.dev/schema/v1.json"
        },
        "$id": {
          "type": "string"
        },
        "$type": {
          "type": "string",
          "const": "service"
        },
        "$version": {
          "type": "integer"
        },
        "$last_updated": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name for this service (e.g., 'Agent X (Tenant)' instead of 'tenant'). Falls back to derived from $id if not set."
        },
        "$system": {
          "type": "string",
          "description": "Reference to system.usm file (e.g. smith-gray/system)"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "built", "deprecated"],
          "default": "built",
          "description": "Implementation status: planned (no code yet), in-progress (partial code), built (code exists), deprecated (replaced by something else)"
        },
        "type": {
          "type": "string",
          "enum": [
            "web-app",
            "api",
            "worker",
            "idp",
            "llm-gateway",
            "agent-flows",
            "database",
            "cache",
            "queue"
          ]
        },
        "runtime": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dev": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "prod": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "deployment_ref": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "testing": {
          "type": "object",
          "properties": {
            "framework": {
              "type": "string"
            },
            "command": {
              "type": "string"
            },
            "coverage_target": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "security": {
          "type": "object",
          "properties": {
            "auth_method": {
              "type": "string"
            },
            "secrets_ref": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "future": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "decision": {
                "type": "string"
              },
              "rationale": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": ["proposed", "accepted", "rejected", "superseded"],
                "default": "accepted",
                "description": "ADR status"
              },
              "alternatives": {
                "type": "array",
                "description": "Alternatives considered and rejected (ADR-style)",
                "items": {
                  "type": "object",
                  "properties": {
                    "option": {
                      "type": "string",
                      "description": "The alternative that was considered"
                    },
                    "rejected_because": {
                      "type": "string",
                      "description": "Why this alternative was rejected"
                    }
                  },
                  "required": ["option", "rejected_because"],
                  "additionalProperties": false
                }
              },
              "consequences": {
                "type": "string",
                "description": "What consequences this decision has (positive and negative)"
              }
            },
            "required": [
              "id",
              "decision",
              "rationale"
            ],
            "additionalProperties": false
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "name",
              "purpose"
            ],
            "additionalProperties": false
          }
        },
        "project_structure": {
          "type": "string",
          "description": "Markdown describing the project's directory layout (app/, lib/, components/, etc.)"
        },
        "rbac": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "roles": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "level": { "type": "string" },
                  "helper": { "type": "string" }
                },
                "required": ["name", "level"],
                "additionalProperties": false
              }
            },
            "helpers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "purpose": { "type": "string" }
                },
                "required": ["name", "purpose"],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "tech_stack": {
          "type": "object",
          "description": "Detailed tech stack mapping (framework, language, styling, database, auth, etc.)",
          "additionalProperties": { "type": "string" }
        },
        "conventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Service-level conventions (import aliases, auth patterns, code rules)"
        },
        "testing_details": {
          "type": "object",
          "properties": {
            "framework": { "type": "string" },
            "e2e_path": { "type": "string" },
            "command": { "type": "string" },
            "auth_testing": { "type": "string" }
          },
          "additionalProperties": true
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "implementation": { "type": "string" },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": { "type": "string" },
                    "value": { "type": "string" }
                  },
                  "required": ["key", "value"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["id", "name", "description"],
            "additionalProperties": false
          },
          "description": "Shared patterns used by this service (e.g., prisma-singleton, litellm-proxy, zitadel-oidc)"
        },
        "runtime_details": {
          "type": "string",
          "description": "Markdown describing the agent runtime architecture (Docker sandbox, config-generator, warm pool, etc.)"
        },
        "infrastructure": {
          "type": "object",
          "description": "Terraform-managed infrastructure for this service. Extracted by `usm scan infrastructure`.",
          "properties": {
            "provider": { "type": "string", "enum": ["aws", "gcp", "azure", "other"] },
            "region": { "type": "string" },
            "compute": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["fargate", "ec2", "lambda", "cloud-run", "cloud-function", "other"] },
                "mode": { "type": "string", "enum": ["on-demand", "spot", "mixed"] },
                "cpu": { "type": "integer" },
                "memory_mb": { "type": "integer" },
                "desired_count": { "type": "integer" }
              }
            },
            "networking": {
              "type": "object",
              "properties": {
                "alb_listener_rule": { "type": "string" },
                "hostnames": { "type": "array", "items": { "type": "string" } },
                "port": { "type": "integer" },
                "protocol": { "type": "string", "enum": ["http", "https", "grpc"] },
                "tls_termination": { "type": "string", "enum": ["alb", "cloudflare", "service", "none"] }
              }
            },
            "data": {
              "type": "object",
              "properties": {
                "engine": { "type": "string" },
                "instance_class": { "type": "string" },
                "multi_az": { "type": "boolean" },
                "backup_retention_days": { "type": "integer" }
              }
            },
            "scaling": {
              "type": "object",
              "properties": {
                "min": { "type": "integer" },
                "max": { "type": "integer" },
                "target_cpu_percent": { "type": "integer" }
              }
            },
            "secrets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "source": { "type": "string", "enum": ["ssm", "secrets-manager", "env", "vault"] },
                  "purpose": { "type": "string" }
                }
              }
            },
            "monitoring": {
              "type": "object",
              "properties": {
                "logs": { "type": "string", "enum": ["cloudwatch", "loki", "datadog", "none"] },
                "metrics": { "type": "string", "enum": ["cloudwatch", "prometheus", "datadog", "none"] },
                "alarms": { "type": "array", "items": { "type": "string" } }
              }
            },
            "cost": {
              "type": "object",
              "properties": {
                "monthly_estimate_usd": { "type": "number" },
                "optimization_notes": { "type": "string" }
              }
            },
            "disaster_recovery": {
              "type": "object",
              "properties": {
                "backup_strategy": { "type": "string" },
                "rto_minutes": { "type": "integer" },
                "rpo_minutes": { "type": "integer" }
              }
            },
            "self_hosting": {
              "type": "object",
              "description": "How to self-host this service (sub-section of deployment.infrastructure)",
              "properties": {
                "supported": { "type": "boolean" },
                "requirements": { "type": "array", "items": { "type": "string" } },
                "guide_ref": { "type": "string" }
              }
            }
          }
        }
      },
      "required": [
        "$schema",
        "$id",
        "$type",
        "$version",
        "summary",
        "$system",
        "type",
        "runtime"
      ],
      "additionalProperties": false
    },
    "featureFile": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "const": "https://usm.dev/schema/v1.json"
        },
        "$id": {
          "type": "string"
        },
        "$type": {
          "type": "string",
          "const": "feature"
        },
        "$version": {
          "type": "integer"
        },
        "$last_updated": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "$system": {
          "type": "string"
        },
        "$service": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in-progress", "built", "deprecated"],
          "default": "built",
